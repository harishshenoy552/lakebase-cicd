# Copy to .env and `source .env` to run the scripts locally.
export PROJECT=projects/orders-api        # Lakebase project path
export DATABRICKS_PROFILE=DEFAULT          # your Databricks CLI profile
export DB_NAME=orders                      # application database
export CU_MIN=0.5                          # ephemeral endpoint autoscale floor
export CU_MAX=2.0                          # ephemeral endpoint autoscale ceiling
# export MIGRATION_TOOL=liquibase          # uncomment to use the Liquibase path

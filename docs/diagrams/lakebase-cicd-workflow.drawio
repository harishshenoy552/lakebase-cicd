<mxfile host="app.diagrams.net" type="device">
  <diagram name="Lakebase CI/CD workflow" id="lakebase-cicd">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="960" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Lane backgrounds -->
        <mxCell id="lanePR" value="Pull-request build&#10;(developer's fast loop)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4FAFE;strokeColor=#5DADE2;verticalAlign=top;fontStyle=1;fontColor=#1A5276;fontSize=13;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="120" y="90" width="300" height="440" as="geometry" />
        </mxCell>
        <mxCell id="laneMain" value="main build&#10;(DBA control gate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4FCF6;strokeColor=#58D68D;verticalAlign=top;fontStyle=1;fontColor=#196F3D;fontSize=13;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="120" y="580" width="300" height="330" as="geometry" />
        </mxCell>
        <mxCell id="laneLake" value="Lakebase project" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF4FC;strokeColor=#BB8FCE;verticalAlign=top;fontStyle=1;fontColor=#6C3483;fontSize=13;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="60" width="240" height="270" as="geometry" />
        </mxCell>

        <!-- Nodes -->
        <mxCell id="pr" value="Developer opens&#10;a Pull Request" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E1E1E1;strokeColor=#808080;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="180" y="20" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="create" value="Create copy-on-write&#10;DB branch  (ci-pr-N)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4E6F1;strokeColor=#5DADE2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="130" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="migrate" value="Apply migrations&#10;(SQL or Liquibase)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4E6F1;strokeColor=#5DADE2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="230" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="test" value="Run tests against&#10;production-seeded data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4E6F1;strokeColor=#5DADE2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="330" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="gate" value="Tests&#10;pass?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FCF3CF;strokeColor=#D4AC0D;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="210" y="420" width="120" height="90" as="geometry" />
        </mxCell>
        <mxCell id="fix" value="Fix &amp; push&#10;new commit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#E74C3C;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="470" y="435" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="teardown" value="Teardown ephemeral&#10;branch  (always)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4E6F1;strokeColor=#5DADE2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="455" y="560" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="merge" value="Merge PR to main" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#58D68D;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="620" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="dba" value="DBA&#10;approval&#10;gate" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FCF3CF;strokeColor=#D4AC0D;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="210" y="700" width="120" height="90" as="geometry" />
        </mxCell>
        <mxCell id="promote" value="Promote same migration&#10;to production" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ABEBC6;strokeColor=#27AE60;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="830" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="prod" value="production branch&#10;(protected)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#27AE60;fontSize=12;boundedLbl=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="100" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ephem" value="ci-pr-N branch&#10;(scales to zero)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#E67E22;fontSize=12;boundedLbl=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="230" width="170" height="80" as="geometry" />
        </mxCell>

        <!-- Main flow edges -->
        <mxCell id="e_pr" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#333333;endArrow=block;" edge="1" parent="1" source="pr" target="create"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_cm" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#333333;endArrow=block;" edge="1" parent="1" source="create" target="migrate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_mt" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#333333;endArrow=block;" edge="1" parent="1" source="migrate" target="test"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_tg" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#333333;endArrow=block;" edge="1" parent="1" source="test" target="gate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_pass" value="pass" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#229954;fontColor=#1E8449;endArrow=block;" edge="1" parent="1" source="gate" target="merge"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_fail" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E74C3C;fontColor=#C0392B;endArrow=block;" edge="1" parent="1" source="gate" target="fix"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rerun" value="re-run" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;strokeColor=#E74C3C;fontColor=#C0392B;endArrow=block;" edge="1" parent="1" source="fix" target="create"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_close" value="on close" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;strokeColor=#333333;endArrow=block;" edge="1" parent="1" source="gate" target="teardown"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_md" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#333333;endArrow=block;" edge="1" parent="1" source="merge" target="dba"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_dp" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#333333;endArrow=block;" edge="1" parent="1" source="dba" target="promote"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Lakebase relationships -->
        <mxCell id="e_cow" value="instant&#10;copy-on-write" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;strokeColor=#8E44AD;fontColor=#6C3483;endArrow=open;" edge="1" parent="1" source="prod" target="ephem"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_creates" value="creates" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;dashPattern=1 4;strokeColor=#2E86C1;fontColor=#2471A3;endArrow=open;" edge="1" parent="1" source="create" target="ephem"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_apply" value="applies&#10;migration" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;dashPattern=1 4;strokeColor=#27AE60;fontColor=#1E8449;endArrow=open;" edge="1" parent="1" source="promote" target="prod"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
